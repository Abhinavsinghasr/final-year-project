/* ======================================================== */
bool isValueSet(const char* value) {
  if (value == nullptr) return false;
  if (strlen(value) == 0) return false;

  String s = String(value);
  s.trim();

  if (s.length() == 0) return false;

  // Common placeholder checks
  if (s == "Wifi_Name") return false;
  if (s == "Wifi_Password") return false;
  if (s == "Blynk_Template_Auth_Token") return false;
  if (s == "Blynk_Template_ID") return false;
  if (s == "Blynk_Template_Name") return false;
  if (s == "YOUR_TELEGRAM_BOT_TOKEN") return false;
  if (s == "YOUR_TELEGRAM_CHAT_ID") return false;
  if (s == "null") return false;
  if (s == "NULL") return false;
  if (s == "-") return false;

  return true;
}

/* ======================================================== */
void setupConnectivity() {

  wifiEnabled = isValueSet(ssid) && isValueSet(pass);
  blynkEnabled = wifiEnabled &&
                 isValueSet(auth) &&
                 isValueSet(BLYNK_TEMPLATE_ID) &&
                 isValueSet(BLYNK_TEMPLATE_NAME);
  telegramEnabled = wifiEnabled &&
                    isValueSet(telegramBotToken) &&
                    isValueSet(telegramChatID);

  if (!wifiEnabled) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Local Mode");
    lcd.setCursor(0, 1);
    lcd.print("WiFi Not Set");
    Serial.println("WiFi credentials not set. Running in local mode.");
    delay(1500);
    return;
  }

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting WiFi");
  Serial.println("Connecting to WiFi...");

  WiFi.begin(ssid, pass);

  unsigned long wifiStart = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - wifiStart < 10000) {
    delay(500);
    Serial.print(".");
    lcd.setCursor(0, 1);
    lcd.print("Please wait... ");
  }
  Serial.println();

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("WiFi Connected");
    Serial.print("IP: ");
    Serial.println(WiFi.localIP());

    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("WiFi Connected");

    if (blynkEnabled) {
      lcd.setCursor(0, 1);
      lcd.print("Connecting Blynk");
      Serial.println("Connecting Blynk...");
      Blynk.config(auth);
      Blynk.connect(5000);

      if (Blynk.connected()) {
        Serial.println("Blynk Connected");
      } else {
        Serial.println("Blynk not connected. Continuing local mode.");
      }
    } else {
      Serial.println("Blynk credentials not set. Skipping Blynk.");
      lcd.setCursor(0, 1);
      lcd.print("Blynk Disabled  ");
    }

    delay(1500);
  }
  else {
    Serial.println("WiFi connection failed. Running in local mode.");
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Offline Mode");
    lcd.setCursor(0, 1);
    lcd.print("LCD Working");
    delay(1500);
  }
}

/* ======================================================== */
void setup() {

  Serial.begin(115200);
  pinMode(CAL_BUTTON, INPUT_PULLUP);

  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Energy Meter");
  lcd.setCursor(0, 1);
  lcd.print("Starting...");
  delay(1000);

  EEPROM.begin(64);

  EEPROM.get(addrVcal, vCalibration);
  EEPROM.get(addrIcal, currCalibration);

  if (isnan(vCalibration) || vCalibration == 0) vCalibration = 42.5;
  if (isnan(currCalibration) || currCalibration == 0) currCalibration = 1.00;

  readEnergyDataFromEEPROM();

  emon.voltage(35, vCalibration, 1.7);
  emon.current(34, currCalibration);

  setupConnectivity();

  lastMillis = millis();

  timer.setInterval(2000L, sendEnergyData);
  timer.setInterval(5000L, changeDisplayPage);
  timer.setInterval(60000L, sendTelegramReport);

  lcd.clear();
}

/* ======================================================== */
void loop() {

  if (wifiEnabled && WiFi.status() == WL_CONNECTED && blynkEnabled) {
    Blynk.run();
  }

  timer.run();
  checkButtonCalibration();
}

/* ======================================================== */
void sendEnergyData() {

  emon.calcVI(20, 2000);

  float Vrms = emon.Vrms;
  float Irms = emon.Irms;
  float apparentPower = emon.apparentPower;

  /* ===== ENERGY CALCULATION ===== */
  unsigned long currentMillis = millis();
  kWh += apparentPower * (currentMillis - lastMillis) / 3600000000.0;
  lastMillis = currentMillis;

  cost = kWh * ratePerkWh;

  saveEnergyDataToEEPROM();

  /* ===== BLYNK UPDATE ===== */
  if (wifiEnabled && WiFi.status() == WL_CONNECTED && blynkEnabled && Blynk.connected()) {
    Blynk.virtualWrite(V0, Vrms);
    Blynk.virtualWrite(V1, Irms);
    Blynk.virtualWrite(V2, apparentPower);
    Blynk.virtualWrite(V3, kWh);
    Blynk.virtualWrite(V4, cost);
  }

  updateLCD();
}

/* ======================================================== */
/* ========= CALIBRATION (UNCHANGED AS REQUESTED) ========= */
/* ======================================================== */
void checkButtonCalibration() {

  if (digitalRead(CAL_BUTTON) == LOW) {

    if (!buttonHeld) {
      buttonPressTime = millis();
      buttonHeld = true;
    }

    if (millis() - buttonPressTime >= 3000) {

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("Calibrating...");
      delay(1000);

      performCalibration();

      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("System");
      lcd.setCursor(0,1);
      lcd.print("Calibrated");
      delay(2000);

      buttonHeld = false;
    }

  } else {
    buttonHeld = false;
  }
}

void performCalibration() {

  float actualVoltage = 230.0;
  float actualPower   = 60.0;

  float avgVoltage = 0;
  float avgPower = 0;

  for (int i = 0; i < 10; i++) {

    emon.calcVI(20, 2000);

    avgVoltage += emon.Vrms;
    avgPower += emon.apparentPower;

    delay(500);
  }

  avgVoltage /= 10.0;
  avgPower /= 10.0;

  if (avgVoltage != 0) {
    vCalibration = vCalibration * (actualVoltage / avgVoltage);
  }

  if (avgPower != 0) {
    currCalibration = currCalibration * (actualPower / avgPower);
  }

  EEPROM.put(addrVcal, vCalibration);
  EEPROM.put(addrIcal, currCalibration);
  EEPROM.commit();

  emon.voltage(35, vCalibration, 1.7);
  emon.current(34, currCalibration);
}

/* ======================================================== */
void sendTelegramReport() {

  if (!telegramEnabled) return;
  if (!wifiEnabled) return;
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;

  String url = "https://api.telegram.org/bot" + String(telegramBotToken) + "/sendMessage";

  http.begin(url);
  http.addHeader("Content-Type", "application/json");

  DynamicJsonDocument doc(256);

  doc["chat_id"] = telegramChatID;
  doc["text"] =
    "📊 Energy Report\n"
    "Voltage: " + String(emon.Vrms, 0) + "V\n" +
    "Power: " + String(emon.apparentPower, 0) + "W\n" +
    "Energy: " + String(kWh, 3) + " kWh\n" +
    "Cost: ₹" + String(cost, 2);

  String payload;
  serializeJson(doc, payload);

  int httpCode = http.POST(payload);
  Serial.print("Telegram HTTP Code: ");
  Serial.println(httpCode);

  http.end();
}

/* ======================================================== */
void readEnergyDataFromEEPROM() {

  EEPROM.get(addrKWh, kWh);
  EEPROM.get(addrCost, cost);

  if (isnan(kWh) || kWh < 0) kWh = 0;
  if (isnan(cost) || cost < 0) cost = 0;
}

void saveEnergyDataToEEPROM() {

  EEPROM.put(addrKWh, kWh);
  EEPROM.put(addrCost, cost);
  EEPROM.commit();
}

/* ======================================================== */
void updateLCD() {

  lcd.clear();

  if (displayPage == 0) {
    lcd.setCursor(0, 0);
    lcd.printf("V:%.0f I:%.2f", emon.Vrms, emon.Irms);

    lcd.setCursor(0, 1);
    lcd.printf("P:%.0fW", emon.apparentPower);
  }
  else {
    lcd.setCursor(0, 0);
    lcd.printf("E:%.3fkWh", kWh);

    lcd.setCursor(0, 1);
    lcd.printf("Cost:%.2f", cost);
  }
}

void changeDisplayPage() {
  displayPage = (displayPage + 1) % 2;
}
